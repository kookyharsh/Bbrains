generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["views"]
}

datasource db {
  provider = "postgresql"
}

model College {
  id        Int      @id @default(autoincrement()) @map("college_id")
  name      String   @db.VarChar(50)
  addressId Int?     @map("address_id")
  email     String   @db.VarChar(50)
  regNo     String   @map("reg_no") @db.VarChar(50)
  createdAt DateTime @default(now())
  address   Address? @relation(fields: [addressId], references: [id])
  users     User[]
  features  Json?    @default("{}")

  @@map("college")
}

model User {
  // Store Clerk's user id (e.g. "user_...") as the primary key.
  id                 String               @id @map("user_id")
  collegeId          Int                  @map("college_id")
  email              String               @unique @db.VarChar(50)
  username           String               @unique @db.VarChar(32)
  password           String?              @db.VarChar(255)
  type               UserRole             @default(student)
  createdAt          DateTime             @default(now()) @map("created_at")
  updatedAt          DateTime             @updatedAt @map("updated_at")
  addresses          Address[]
  announcements      Announcement[]
  auditLogs          AuditLog[]
  cartItems          Cart[]
  enrollments        Enrollment[]
  grades             Grade[]
  leaderboards       Leaderboard[]
  orders             Order[]
  products           Product[]
  submissions        Submission[]
  transactions       TransactionHistory[]
  library            Library[]
  college            College              @relation(fields: [collegeId], references: [id])
  userAchievements   UserAchievements[]
  userDetails        UserDetails?
  roles              UserRoles[]
  wallet             Wallet?
  xp                 Xp?
  attendances        Attendance[]         @relation("userAttendance")
  markedAttendances  Attendance[]         @relation("markerAttendance")
  notifications      Notification[]
  suggestions        Suggestion[]
  streak             Streak?
  preference         UserPreference?
  chatMessages       ChatMessage[]
  classTeacherCourse Course?              @relation("CourseClassTeacher")
  assessments        Assessment[]         @relation("AssessmentCreator")
  assessmentResults  AssessmentResult[]   @relation("AssessmentStudent")

  @@map("user")
}

model UserDetails {
  id              Int      @id @default(autoincrement())
  userId          String   @unique @map("user_id")
  avatar          String?
  firstName       String   @map("first_name") @db.VarChar(25)
  middlename      String?
  lastName        String   @map("last_name") @db.VarChar(25)
  sex             Sex
  dob             DateTime @db.Date
  phone           String?  @db.VarChar(15)
  bio             String?  @db.Text
  teacherSubjects Json?    @map("teacher_subjects")
  addressId       Int?     @map("address_id")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  address         Address? @relation(fields: [addressId], references: [id])
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_details")
}

model Address {
  id           Int           @id @default(autoincrement())
  userId       String?       @map("user_id")
  addressLine1 String        @map("address_line1") @db.VarChar(255)
  addressLine2 String?       @map("address_line2") @db.VarChar(255)
  city         String        @db.VarChar(50)
  state        String?       @db.VarChar(100)
  postalCode   String?       @map("postal_code") @db.VarChar(10)
  country      String        @db.VarChar(100)
  user         User?         @relation(fields: [userId], references: [id], onDelete: Cascade)
  colleges     College[]
  userDetails  UserDetails[]

  @@map("address")
}

model Course {
  id              Int                 @id @default(autoincrement()) @map("course_id")
  name            String              @db.VarChar(100)
  description     String?             @db.VarChar(255)
  standard        String?             @db.VarChar(50)
  feePerStudent   Decimal?            @map("fee_per_student") @db.Decimal(10, 2)
  durationValue   Int?                @map("duration_value")
  durationUnit    CourseDurationUnit? @map("duration_unit")
  studentCapacity Int?                @map("student_capacity")
  classTeacherId  String?             @unique @map("class_teacher_id")
  subjects        Json?
  timetable       Json?
  createdAt       DateTime            @default(now()) @map("created_at")
  updatedAt       DateTime            @updatedAt @map("updated_at")
  assignments     Assignment[]
  enrollments     Enrollment[]
  classTeacher    User?               @relation("CourseClassTeacher", fields: [classTeacherId], references: [id], onDelete: SetNull)
  assessments     Assessment[]

  @@map("course")
}

model Enrollment {
  userId     String   @map("user_id")
  courseId   Int      @map("course_id")
  enrolledAt DateTime @default(now()) @map("enrolled_at")
  grade      String?  @db.VarChar(5)
  course     Course   @relation(fields: [courseId], references: [id])
  user       User     @relation(fields: [userId], references: [id])

  @@id([userId, courseId])
  @@index([courseId])
  @@map("enrollment")
}

model Assignment {
  id          Int          @id @default(autoincrement()) @map("assignment_id")
  courseId    Int          @map("course_id")
  title       String       @db.VarChar(100)
  description String?      @db.VarChar(255)
  content     String?
  file        String?
  dueDate     DateTime     @map("due_date") @db.Date
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  course      Course       @relation(fields: [courseId], references: [id])
  grades      Grade[]
  submissions Submission[]

  @@map("assignment")
}

model Submission {
  id           Int        @id @default(autoincrement()) @map("submission_id")
  assignmentId Int        @map("assignment_id")
  userId       String     @map("user_id")
  filePath     String     @map("file_path") @db.VarChar(255)
  submittedAt  DateTime   @default(now()) @map("submitted_at")
  assignment   Assignment @relation(fields: [assignmentId], references: [id])
  user         User       @relation(fields: [userId], references: [id])

  @@index([assignmentId])
  @@index([userId])
  @@map("submission")
}

model Grade {
  id           Int        @id @default(autoincrement())
  userId       String     @map("user_id")
  assignmentId Int        @map("assignment_id")
  grade        String     @db.VarChar(5)
  gradedAt     DateTime   @default(now()) @map("graded_at")
  gradedBy     String     @map("checked_by") @db.VarChar(50)
  assignment   Assignment @relation(fields: [assignmentId], references: [id])
  user         User       @relation(fields: [userId], references: [id])

  @@index([assignmentId])
  @@index([userId])
  @@map("grade")
}

model Assessment {
  id             Int                @id @default(autoincrement()) @map("assessment_id")
  courseId       Int                @map("course_id")
  createdById    String             @map("created_by_id")
  subject        String             @db.VarChar(100)
  topic          String             @db.VarChar(150)
  assessmentType AssessmentType     @default(test) @map("assessment_type")
  assessmentDate DateTime           @map("assessment_date") @db.Date
  totalMarks     Decimal            @map("total_marks") @db.Decimal(8, 2)
  createdAt      DateTime           @default(now()) @map("created_at")
  updatedAt      DateTime           @updatedAt @map("updated_at")
  course         Course             @relation(fields: [courseId], references: [id], onDelete: Cascade)
  createdBy      User               @relation("AssessmentCreator", fields: [createdById], references: [id], onDelete: Cascade)
  results        AssessmentResult[]

  @@index([courseId, assessmentDate])
  @@index([createdById, assessmentDate])
  @@map("assessment")
}

model AssessmentResult {
  id            Int        @id @default(autoincrement()) @map("assessment_result_id")
  assessmentId  Int        @map("assessment_id")
  studentId     String     @map("student_id")
  marksObtained Decimal    @map("marks_obtained") @db.Decimal(8, 2)
  remark        String?    @db.VarChar(255)
  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @updatedAt @map("updated_at")
  assessment    Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  student       User       @relation("AssessmentStudent", fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([assessmentId, studentId])
  @@index([studentId, createdAt(sort: Desc)])
  @@map("assessment_result")
}

model Role {
  id          Int         @id @default(autoincrement()) @map("role_id")
  name        String      @unique @db.VarChar(50)
  description String?     @db.VarChar(255)
  users       UserRoles[]

  @@map("role")
}

model UserRoles {
  userId     String   @map("user_id")
  roleId     Int      @map("role_id")
  assignedAt DateTime @default(now()) @map("assigned_at")
  role       Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_roles")
}

model Xp {
  id        Int      @id @default(autoincrement())
  userId    String   @unique @map("user_id")
  xp        Decimal  @default(0)
  level     Int      @default(1)
  updatedAt DateTime @updatedAt @map("updated_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("xp")
}

model Level {
  id          Int @id @default(autoincrement())
  levelNumber Int @unique
  requiredXp  Decimal @db.Decimal(10, 2)

  @@map("level")
}

model Leaderboard {
  id          Int                 @id @default(autoincrement())
  userId      String              @map("user_id")
  score       Decimal             @db.Decimal(10, 2)
  category    LeaderboardCategory @default(allTime)
  periodStart DateTime
  periodEnd   DateTime?
  rank        Int?
  createdAt   DateTime            @default(now()) @map("created_at")
  updatedAt   DateTime            @updatedAt @map("updated_at")
  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, category, periodStart])
  @@index([category, score(sort: Desc)])
  @@map("leaderboard")
}

model Achievement {
  id          String             @id @default(uuid()) @map("achievement_id")
  name        String             @db.VarChar(100)
  description String?            @db.VarChar(255)
  tier        Int
  rewardXP    Int
  rewardCoins Int
  icon        String?
  category    String?            @db.VarChar(50)
  users       UserAchievements[]

  @@map("achievement")
}

model UserAchievements {
  userId        String      @map("user_id")
  achievementId String      @map("achievement_id")
  unlockedAt    DateTime    @default(now()) @map("unlocked_at")
  achievement   Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, achievementId])
  @@map("user_achievements")
}

model Wallet {
  id      String  @id @map("wallet_id") @db.VarChar(255)
  userId  String  @unique @map("user_id")
  pin     String? @db.VarChar(255)
  balance Decimal @default(500.00) @db.Decimal(10, 2)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("wallet")
}

model Product {
  id           Int             @id @default(autoincrement()) @map("product_id")
  creatorId    String          @map("creator_id")
  name         String          @db.VarChar(100)
  description  String?         @db.VarChar(255)
  image        String?         @db.VarChar(255)
  price        Decimal         @db.Decimal(10, 2)
  stock        Int
  approval     ProductApproval @default(pending)
  metadata     Json? // category, fileUrl, fileType, previewImages, themeConfig, version, downloads
  createdAt    DateTime        @default(now()) @map("created_at")
  cartItems    Cart[]
  orderItems   OrderItem[]
  libraryItems Library[]
  creator      User            @relation(fields: [creatorId], references: [id], onDelete: Cascade)

  @@index([name])
  @@map("product")
}

model Order {
  id          Int         @id @default(autoincrement()) @map("order_id")
  userId      String      @map("user_id")
  status      String?     @default("pending")
  orderDate   DateTime    @default(now()) @map("order_date")
  totalAmount Decimal     @map("total_amount") @db.Decimal(10, 2)
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  items       OrderItem[]

  @@index([userId])
  @@map("order")
}

model OrderItem {
  id        Int     @id @default(autoincrement())
  orderId   Int     @map("order_id")
  productId Int     @map("product_id")
  quantity  Int
  price     Decimal @db.Decimal(10, 2)
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id])

  @@map("order_item")
}

model TransactionHistory {
  id              Int               @id @default(autoincrement())
  userId          String            @map("user_id")
  recordedById    String?           @map("recorded_by_id")
  relatedUserId   String?           @map("related_user_id")
  entryGroupId    String?           @map("entry_group_id") @db.VarChar(64)
  transactionDate DateTime          @default(now()) @map("transaction_date")
  amount          Decimal           @db.Decimal(10, 2)
  type            TransactionType
  category        String            @default("other") @db.VarChar(30)
  status          TransactionStatus @default(pending)
  paymentMode     String?           @map("payment_mode") @db.VarChar(30)
  referenceId     String?           @map("reference_id") @db.VarChar(100)
  primaryRecord   Boolean           @default(true) @map("primary_record")
  note            String?           @db.VarChar(255)
  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([recordedById, primaryRecord, transactionDate(sort: Desc)])
  @@index([relatedUserId])
  @@index([category, transactionDate(sort: Desc)])
  @@index([userId, transactionDate(sort: Desc)])
  @@map("transaction_history")
}

model Cart {
  id        Int     @id @default(autoincrement())
  userId    String  @map("user_id")
  productId Int     @map("product_id")
  quantity  Int
  price     Decimal @db.Decimal(10, 2)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@map("cart")
}

model Library {
  id          Int      @id @default(autoincrement())
  userId      String   @map("user_id")
  productId   Int      @map("product_id")
  purchasedAt DateTime @default(now()) @map("purchased_at")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@map("library")
}

model Announcement {
  id          Int      @id @default(autoincrement())
  userId      String   @map("user_id")
  title       String   @db.VarChar(100)
  description String?
  image       String?
  createdAt   DateTime @default(now()) @map("created_at")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("announcement")
}

model AuditLog {
  id        Int         @id @default(autoincrement())
  userId    String?     @map("user_id")
  category  LogCategory
  action    String
  entity    String
  entityId  String      @map("entityId")
  change    Json?
  reason    String?
  createdAt DateTime    @default(now()) @map("created_at")
  user      User?       @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([category])
  @@index([userId])
  @@map("audit_log")
}

enum Sex {
  male
  female
  other
}

enum UserRole {
  student
  teacher
  admin
  staff
  superadmin
}

enum CourseDurationUnit {
  months
  years
}

enum TransactionType {
  credit
  debit
}

enum TransactionStatus {
  success
  failed
  pending
}

enum ProductApproval {
  pending
  approved
  rejected
}

enum LeaderboardCategory {
  weekly
  monthly
  allTime
  course
}

enum LogCategory {
  AUTH
  ACADEMIC
  MARKET
  FINANCE
  USER
  SYSTEM
}

enum AssessmentType {
  test
  exam
}

model Event {
  id          Int      @id @default(autoincrement())
  title       String   @db.VarChar(100)
  description String?
  banner      String?
  startDate   DateTime @db.Date
  endDate     DateTime @db.Date
  date        DateTime
  location    String?  @db.VarChar(100)
  type        String?  @db.VarChar(50)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("event")
}

model Attendance {
  id        Int      @id @default(autoincrement())
  userId    String   @map("user_id")
  markedBy  String?  @map("marked_by")
  date      DateTime @db.Date
  status    String   @db.VarChar(20)
  notes     String?
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation("userAttendance", fields: [userId], references: [id], onDelete: Cascade)
  marker    User?    @relation("markerAttendance", fields: [markedBy], references: [id], onDelete: SetNull)

  @@index([userId, date])
  @@map("attendance")
}

model Streak {
  id            Int       @id @default(autoincrement())
  userId        String    @unique @map("user_id")
  currentStreak Int       @default(0)
  lastClaimedAt DateTime?
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("streak")
}

model UserPreference {
  id        String   @id @default(cuid()) @map("preference_id")
  userId    String   @unique @map("user_id")
  theme     String? // active theme ID or name
  settings  Json? // other user settings (language, notifications, etc.)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_preference")
}

model Notification {
  id        Int       @id @default(autoincrement())
  userId    String    @map("user_id")
  title     String    @db.VarChar(100)
  message   String?
  type      String    @db.VarChar(50) // mention, system, chat, announcement, achievement, attendance, grade
  relatedId String?   @map("related_id")
  readAt    DateTime?
  createdAt DateTime  @default(now()) @map("created_at")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
  @@map("notification")
}

model SystemConfig {
  id          Int      @id @default(autoincrement())
  key         String   @unique @db.VarChar(100)
  value       String   @db.Text
  description String?
  type        String   @default("string") // string, number, boolean, json
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("system_config")
}

model Suggestion {
  id        Int      @id @default(autoincrement())
  userId    String   @map("user_id")
  title     String   @db.VarChar(100)
  content   String   @db.Text
  status    String   @default("pending") // pending, reviewed, implemented, rejected
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("suggestion")
}

model ChatMessage {
  id          String   @id @default(uuid())
  chatId      String   @default("default") @map("chat_id")
  userId      String   @map("user_id")
  username    String?
  displayName String?  @map("display_name")
  avatar      String?
  role        String?
  content     String   @db.Text
  mentions    Json?    @default("[]")
  replyTo     String?  @map("reply_to")
  attachments Json?    @default("[]")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("chat_messages")
}
